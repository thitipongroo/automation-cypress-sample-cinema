    "lint": "eslint cypress/**/*.js"
  },
  "devDependencies": {
    "cypress": "^13.17.0",
    "eslint": "^8.57.0",
    "eslint-plugin-cypress": "^3.5.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0"
  }
}