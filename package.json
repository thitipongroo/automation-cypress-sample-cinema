{
  "name": "automation-cypress-sample-cinema",
  "version": "1.0.0",
  "description": "E2E automation test suite for cinema booking platform using Cypress + POM",
  "author": "Thitipong Roongpraser",
  "license": "MIT",
  "scripts": {
    "test": "cypress run",
    "test:headed": "cypress run --headed",
